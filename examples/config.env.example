# Example environment configuration
# Copy this file and customize for your environment:
#   cp examples/config.env.example config.env
#   source config.env
#   ./collect_from_multiple_clusters.sh ...

# OCM Configuration (optional)
# If not set, uses your default OCM configuration
# export OCM_CONFIG="${HOME}/.config/ocm/ocm.json"

# Staging Clusters for Version Verification (optional)
# Used by collect_operator_health.sh to determine expected operator versions
export STAGING_CLUSTERS=("staging-cluster-1" "staging-cluster-2" "staging-cluster-3")

# Expected Operator Version (alternative to staging cluster lookup)
# Use this if you know the expected version and don't have staging clusters
# export EXPECTED_VERSION="abc123def456"

# Debug Mode (optional)
# Enable detailed diagnostics during collection
# export DEBUG=true

# Operator-Specific Settings (customize for your operator)
export NAMESPACE="openshift-monitoring"
export DEPLOYMENT="configure-alertmanager-operator"
export OPERATOR_NAME="configure-alertmanager-operator"

# SAAS File for version lookup (if using app-interface integration)
export SAAS_FILE="saas-configure-alertmanager-operator.yaml"
